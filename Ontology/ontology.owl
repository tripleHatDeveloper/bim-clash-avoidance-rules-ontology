  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#rationaleText">
    <rdfs:label>rationale text</rdfs:label>
    <rdfs:domain rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#isPinned">
    <rdfs:label>is pinned</rdfs:label>
    <rdfs:domain rdf:resource="#LinkedModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#synchronizationIntervalHours">
    <rdfs:label>synchronization interval hours</rdfs:label>
    <rdfs:domain rdf:resource="#SpecialtyBIMModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#hasValue">
    <rdfs:label>has value</rdfs:label>
    <rdfs:domain rdf:resource="#Measurement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <!-- Named individuals -->
  <owl:NamedIndividual rdf:about="#Millimetre">
    <rdf:type rdf:resource="#UnitOfMeasurement"/>
    <rdfs:label>millimetre</rdfs:label>
  </owl:NamedIndividual>

  <!-- Representative validated rules -->
  <owl:NamedIndividual rdf:about="#Rule_A02_InteriorWallHeight">
    <rdf:type rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:label>Interior wall height constraint</rdfs:label>
    <conditionText>If an interior wall is being created or modified</conditionText>
    <constraintText>Wall height must not exceed the ceiling height threshold minus required MEP clearance.</constraintText>
    <rationaleText>Prevents walls from penetrating ceiling MEP zones and causing hard clashes with HVAC ductwork and other MEP systems routed above ceilings.</rationaleText>
    <appliesTo rdf:resource="#InteriorWall"/>
    <prevents rdf:resource="#HardClash"/>
    <hasRelationshipType rdf:resource="#Spatial"/>
    <hasWorkflowType rdf:resource="#BIMBased"/>
    <hasClashType rdf:resource="#HardClashRule"/>
    <hasRequirementType rdf:resource="#Mandatory"/>
    <hasStageType rdf:resource="#Modelling"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Rule_LinkedModelsPinned">
    <rdf:type rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:label>Linked models must be pinned</rdfs:label>
    <conditionText>If linked discipline or site models are loaded</conditionText>
    <constraintText>All linked models must remain pinned.</constraintText>
    <rationaleText>Prevents unintended model shifts that create false clashes or obscure actual coordination issues.</rationaleText>
    <appliesTo rdf:resource="#LinkedModel"/>
    <prevents rdf:resource="#HardClash"/>
    <hasRelationshipType rdf:resource="#Recommendation"/>
    <hasWorkflowType rdf:resource="#BIMBased"/>
    <hasClashType rdf:resource="#HardClashRule"/>
    <hasRequirementType rdf:resource="#Mandatory"/>
    <hasStageType rdf:resource="#Modelling"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Rule_ModelSynchronization">
    <rdf:type rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:label>Hourly central model synchronization</rdfs:label>
    <conditionText>If a work-shared specialty model is being edited</conditionText>
    <constraintText>The model should be synchronized with the central model at least once every hour.</constraintText>
    <rationaleText>Reduces divergence between discipline models and supports consistent coordination.</rationaleText>
    <appliesTo rdf:resource="#SpecialtyBIMModel"/>
    <hasRelationshipType rdf:resource="#Recommendation"/>
    <hasWorkflowType rdf:resource="#BIMBased"/>
    <hasRequirementType rdf:resource="#BestPractice"/>
    <hasStageType rdf:resource="#Modelling"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Rule_StructuralOpenings">
    <rdf:type rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:label>Structural openings must match MEP requirements</rdfs:label>
    <conditionText>If duct or shaft openings are modelled in structural elements</conditionText>
    <constraintText>Opening dimensions must match the exact measurements required by MEP consultants.</constraintText>
    <rationaleText>Prevents physical conflicts between structural elements and routed building services.</rationaleText>
    <appliesTo rdf:resource="#Opening"/>
    <prevents rdf:resource="#HardClash"/>
    <hasRelationshipType rdf:resource="#Spatial"/>
    <hasWorkflowType rdf:resource="#BIMBased"/>
    <hasClashType rdf:resource="#HardClashRule"/>
    <hasRequirementType rdf:resource="#Mandatory"/>
    <hasStageType rdf:resource="#Modelling"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Rule_MEPInsulation">
    <rdf:type rdf:resource="#ClashAvoidanceRule"/>
    <rdfs:label>MEP insulation dimensions must be modelled precisely</rdfs:label>
    <conditionText>If insulated pipes or ducts are being modelled</conditionText>
    <constraintText>Insulation dimensions must be represented according to the specified requirements.</constraintText>
    <rationaleText>Reduces avoidable clashes caused by under-modelled service envelopes.</rationaleText>
    <appliesTo rdf:resource="#Pipe"/>
    <appliesTo rdf:resource="#Duct"/>
    <prevents rdf:resource="#HardClash"/>
    <hasRelationshipType rdf:resource="#Spatial"/>
    <hasWorkflowType rdf:resource="#BIMBased"/>
    <hasClashType rdf:resource="#HardClashRule"/>
    <hasRequirementType rdf:resource="#Mandatory"/>
    <hasStageType rdf:resource="#Modelling"/>
  </owl:NamedIndividual>

</rdf:RDF>
