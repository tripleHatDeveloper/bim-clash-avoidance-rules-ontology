<?xml version="1.0"?>
<rdf:RDF xmlns="https://github.com/tripleHatDeveloper/bim-clash-avoidance-rules-ontology#"
     xml:base="https://github.com/tripleHatDeveloper/bim-clash-avoidance-rules-ontology"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="https://github.com/tripleHatDeveloper/bim-clash-avoidance-rules-ontology/">
    <rdfs:label xml:lang="en">BIM Coordination Rules and Ontology for Clash Avoidance</rdfs:label>
    <rdfs:comment xml:lang="en">Repository-ready OWL ontology for BIM-based multidisciplinary coordination and clash avoidance. This OWL ontology represents a reduced prototype extract of the full BIM coordination ontology developed in the associated research. It includes only the subset of classes, properties, and coordination rules required for prototype system implementation and reproducibility. The complete ontology contains additional concepts and rules that are not included in this repository version.</rdfs:comment>
  </owl:Ontology>

