<Window x:Class="ClashAvoidancePlugin.UI.ViolationPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClashAvoidanceTutorial - Coordination Rule Violation"
        Width="620" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D7DEEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1"
                                      Color="#0F172A" Opacity="0.07"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0F62FE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0353D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D7DEEA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Header -->
        <Border Background="#FFF4E6" BorderBrush="#F1D2A6" BorderThickness="1"
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="20" Foreground="#B45309"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Coordination Rule Violation Detected"
                               FontSize="14" FontWeight="Bold" Foreground="#92400E"/>
                    <TextBlock Text="Review the constraint(s) below. Correct the model or override with justification."
                               FontSize="12" Foreground="#B45309" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Violations list -->
        <ItemsControl x:Name="ViolationsList" Margin="0,0,0,4">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <!-- Rule label -->
                            <TextBlock Text="{Binding Rule.Label}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1F2937" Margin="0,0,0,6"/>

                            <!-- Element -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Element: " FontSize="11"
                                           Foreground="#6B7280" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ElementDescription}"
                                           FontSize="11" Foreground="#374151"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Violation detail -->
                            <Border Background="#FEF3C7" CornerRadius="4"
                                    Padding="10,6" Margin="0,4,0,6">
                                <TextBlock Text="{Binding ViolationDetail}"
                                           FontSize="12" Foreground="#92400E"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Rationale -->
                            <TextBlock Text="Why this matters:" FontSize="11"
                                       FontWeight="SemiBold" Foreground="#6B7280"
                                       Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding Rule.RationaleText}"
                                       FontSize="11" Foreground="#4B5563"
                                       TextWrapping="Wrap"/>

                            <!-- Corrective action -->
                            <TextBlock Text="Corrective action:" FontSize="11"
                                       FontWeight="SemiBold" Foreground="#6B7280"
                                       Margin="0,6,0,2"/>
                            <TextBlock Text="{Binding Rule.ConstraintText}"
                                       FontSize="11" Foreground="#1F2937"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Override section (collapsed by default) -->
        <Border x:Name="OverridePanel" Visibility="Collapsed"
                Background="#EEF3FF" BorderBrush="#BFD4FF" BorderThickness="1"
                CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Override Justification"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#1E40AF" Margin="0,0,0,6"/>
                <TextBlock Text="Provide a brief professional justification for overriding this rule. This will be recorded in the project override log."
                           FontSize="11" Foreground="#3B82F6"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBox x:Name="JustificationBox"
                         Height="60" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         FontSize="12" Padding="8"
                         BorderBrush="#BFD4FF" BorderThickness="1"/>
            </StackPanel>
        </Border>

        <!-- Action buttons -->
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Override toggle -->
            <Button x:Name="OverrideToggleBtn"
                    Grid.Column="1"
                    Content="Override Rule"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="OverrideToggleBtn_Click"/>

            <!-- Confirm override -->
            <Button x:Name="ConfirmOverrideBtn"
                    Grid.Column="2"
                    Content="Confirm Override"
                    Style="{StaticResource SecondaryButton}"
                    Foreground="#B45309"
                    Visibility="Collapsed"
                    Margin="0,0,8,0"
                    Click="ConfirmOverrideBtn_Click"/>

            <!-- Fix model (closes dialog, designer corrects manually) -->
            <Button x:Name="FixModelBtn"
                    Grid.Column="3"
                    Content="OK — I will fix this"
                    Style="{StaticResource PrimaryButton}"
                    Click="FixModelBtn_Click"/>
        </Grid>

    </StackPanel>
</Window>
