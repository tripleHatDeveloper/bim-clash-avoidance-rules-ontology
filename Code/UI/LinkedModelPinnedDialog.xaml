<Window x:Class="ClashAvoidancePlugin.UI.LinkedModelPinnedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClashAvoidanceTutorial - Linked Model Pinned Status"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D7DEEA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Error icon + message -->
        <Border Background="#FEF2F2" BorderBrush="#FECACA"
                BorderThickness="1" CornerRadius="10"
                Padding="16,14" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✕" FontSize="22" FontWeight="Bold"
                           Foreground="#DC2626"
                           VerticalAlignment="Top"
                           Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="Error!" FontSize="14"
                               FontWeight="Bold" Foreground="#991B1B"
                               Margin="0,0,0,6"/>
                    <!-- Model names populated from code-behind -->
                    <ItemsControl x:Name="ModelNamesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="13" Foreground="#7F1D1D"
                                           TextWrapping="Wrap" Margin="0,0,0,4">
                                    <Run Text="Please pin the model '"/>
                                    <Run Text="{Binding}" FontWeight="SemiBold"/>
                                    <Run Text="'."/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Rationale -->
        <Border Background="#F8FAFF" BorderBrush="#DBEAFE"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10" Margin="0,0,0,20">
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="#1E40AF" LineHeight="18">
                Unpinned linked models may shift position during coordination,
                creating false clashes or obscuring real design conflicts in
                subsequent clash detection reviews.
            </TextBlock>
        </Border>

        <!-- Override section (collapsed by default) -->
        <Border x:Name="OverridePanel" Visibility="Collapsed"
                Background="#FFFBEB" BorderBrush="#FDE68A"
                BorderThickness="1" CornerRadius="8"
                Padding="14" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Override Justification"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#92400E" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="#B45309" Margin="0,0,0,8">
                    Provide a brief justification. This will be recorded
                    in the project override log with your username and timestamp.
                </TextBlock>
                <TextBox x:Name="JustificationBox"
                         Height="56" TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="12" Padding="8"
                         BorderBrush="#FCD34D" BorderThickness="1"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OverrideToggleBtn"
                    Grid.Column="1"
                    Content="Override Rule"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="OverrideToggleBtn_Click"/>

            <Button x:Name="ConfirmOverrideBtn"
                    Grid.Column="2"
                    Content="Confirm Override"
                    Style="{StaticResource SecondaryButton}"
                    Foreground="#B45309"
                    Visibility="Collapsed"
                    Margin="0,0,8,0"
                    Click="ConfirmOverrideBtn_Click"/>

            <Button x:Name="OkBtn"
                    Grid.Column="3"
                    Content="OK — I will pin the model"
                    Style="{StaticResource PrimaryButton}"
                    Click="OkBtn_Click"/>
        </Grid>

    </StackPanel>
</Window>
